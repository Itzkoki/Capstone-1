# ── Dependencies ────────────────────────────────
node_modules/
**/node_modules/

# ── Secrets / environment ───────────────────────
.env
**/.env
.env.*
!**/.env.example

# ── Logs ────────────────────────────────────────
*.log
npm-debug.log*
logs/

# ── OS / editor cruft ───────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build / runtime ─────────────────────────────
dist/
build/
*.tmp

# ── Backups (never commit DB dumps) ─────────────
*.dump
*.dump.enc
*.sql.gz
backups/

# ── GeoIP database (provisioned on the server, not committed) ──
# The GeoLite2 .mmdb is large and updated ~twice a week by MaxMind.
# Install it on the server via geoipupdate — see backend/geo/README.md.
*.mmdb
