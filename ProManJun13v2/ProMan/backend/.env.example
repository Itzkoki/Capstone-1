# Server
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=proman_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=1h

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@example.com

# Google reCAPTCHA v3 (primary, scored)
RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_SKIP_VERIFY=false

# Google reCAPTCHA v2 (checkbox fallback when the v3 score is suspicious)
RECAPTCHA_V2_SITE_KEY=your_recaptcha_v2_site_key
RECAPTCHA_V2_SECRET_KEY=your_recaptcha_v2_secret_key

# Max CAPTCHA verification attempts per IP per 10-minute window
CAPTCHA_RATE_LIMIT_MAX=30
