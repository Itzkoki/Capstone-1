{
  "name": "proman-auth-backend",
  "version": "1.0.0",
  "description": "Secure authentication backend for ProMan using Express and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node test/ruleEngine.golden.js && node test/themeDetection.test.js && node test/thresholds.test.js",
    "test:update": "node test/ruleEngine.golden.js --update",
    "knowledge:build": "node scripts/buildKnowledgeBase.js",
    "knowledge:extract": "node scripts/extractKnowledge.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@maxmind/geoip2-node": "^6.3.4",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "twilio": "^6.0.2"
  }
}
